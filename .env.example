APP_NAME=Job Scraper
APP_ENV=development
DEBUG=true
API_PORT=8001
SCHEDULED_SCRAPE_INTERVAL_HOURS=6
BEAT_POLL_INTERVAL_MINUTES=15

POSTGRES_DB=jobs_db
POSTGRES_USER=jobs_user
POSTGRES_PASSWORD=jobs_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://jobs_user:jobs_password@postgres:5432/jobs_db

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

LOG_LEVEL=INFO

USAJOBS_API_KEY=
USAJOBS_USER_AGENT=your-email@example.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
